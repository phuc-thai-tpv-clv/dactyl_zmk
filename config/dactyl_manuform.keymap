#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp ESC   &kp N1    &kp N2    &kp N3    &kp N4    &kp N5           &kp N6    &kp N7    &kp N8     &kp N9      &kp N0      &kp GRAVE
&kp TAB   &kp Q     &kp W     &kp E     &kp R     &kp T            &kp Y     &kp U     &kp I      &kp O       &kp P       &kp BSLH
&kp CARET &kp A     &kp S     &kp D     &kp F     &kp G            &kp H     &kp J     &kp K      &kp L       &kp SEMI    &kp SQT
&kp LSHFT &kp Z     &kp X     &kp C     &kp V     &kp B            &kp N     &kp M     &kp COMMA  &kp DOT     &kp FSLH    &kp RSHFT
&trans    &trans    &kp MINUS &kp LBKT  &kp LGUI  &kp ENTER        &kp BSPC  &kp MINUS &kp RBKT   &kp EQUAL   &trans      &trans
&none     &none     &none     &none     &none     &none            &none     &none     &none      &none       &none       &none
            >;
        };

        lower_layer {
            bindings = <
&kp GRAVE &kp N1    &kp N2    &kp N3    &kp N4    &kp N5           &kp N6    &kp N7    &kp N8     &kp N9      &kp N0      &kp DEL
&trans    &kp EXCL  &kp AT    &kp HASH  &kp DLLR  &kp PRCNT        &kp CARET &kp AMPS  &kp STAR   &kp LPAR    &kp RPAR    &trans
&trans    &kp LBKT  &kp RBKT  &kp LBRC  &kp RBRC  &kp PIPE         &kp MINUS &kp EQUAL &kp UNDER  &kp PLUS    &kp BSLH    &trans
&trans    &trans    &trans    &trans    &trans    &trans           &kp HOME  &kp PG_DN &trans     &kp INS     &kp PG_UP   &kp END
&trans    &trans    &trans    &trans    &trans    &trans           &trans    &trans    &trans     &trans      &trans      &trans
&none     &none     &none     &none     &none     &none            &none     &none     &none      &none       &none       &none
            >;
        };

        raise_layer {
            bindings = <
&bt BT_CLR &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &bt BT_SEL 3 &out OUT_USB   &kp F7    &kp F8    &kp F9     &kp F10     &kp F11     &kp F12
&trans     &kp F1       &kp F2       &kp F3       &kp F4       &kp F5         &kp LEFT  &kp DOWN  &kp UP     &kp RIGHT   &out OUT_BLE &trans
&trans     &kp F6       &kp C_PREV   &kp C_PP     &kp C_NEXT   &kp C_MUTE     &kp C_VOL_DN &kp C_VOL_UP &kp PSCRN &kp SLCK &kp PAUSE &trans
&trans     &trans       &trans       &mo 3        &trans       &trans         &trans    &trans    &mo 3      &trans      &trans      &trans
&trans     &trans       &trans       &trans       &trans       &trans         &trans    &trans    &trans     &trans      &trans      &trans
&none      &none        &none        &none        &none        &none          &none     &none     &none      &none       &none       &none
            >;
        };

        adjust_layer {
            bindings = <
&sys_reset &bootloader &trans &trans &trans &trans                  &trans &trans &trans &trans &trans &trans
&trans     &trans      &trans &trans &trans &trans                  &trans &trans &trans &trans &trans &trans
&trans     &trans      &trans &trans &trans &trans                  &trans &trans &trans &trans &trans &trans
&trans     &trans      &trans &trans &trans &trans                  &trans &trans &trans &trans &trans &trans
&trans     &trans      &trans &trans &trans &trans                  &trans &trans &trans &trans &trans &trans
&none      &none       &none  &none  &none  &none                   &none  &none  &none  &none  &none  &none
            >;
        };
    };
};
